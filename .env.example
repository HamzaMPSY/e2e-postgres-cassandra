# Local-only sample values. Do not reuse these in shared environments.

COMPOSE_PROJECT_NAME=omnicare_cdc_v2

POSTGRES_DB=orders
POSTGRES_USER=orders_cdc_demo
POSTGRES_PASSWORD=change_me_orders

MYSQL_DATABASE=billing
MYSQL_USER=billing_cdc_demo
MYSQL_PASSWORD=change_me_billing
MYSQL_ROOT_PASSWORD=change_me_root

MONGO_INITDB_ROOT_USERNAME=mongo_admin
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo

CASSANDRA_CLUSTER_NAME=omnicare_cdc
CASSANDRA_DC=dc1

ORACLE_PASSWORD=change_me_oracle

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CA_LOCATION=
DEBEZIUM_SIGNAL_TOPIC=cdc.local.omnicare.signals
SCHEMA_REGISTRY_URL=http://schema-registry:8081
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_KEYSPACE=omnicare_dashboard
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_PROTOCOL_VERSION=5
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=
CASSANDRA_SSL_CA_CERT=
MAX_PAYMENT_AMOUNT_CENTS=10000000
PAYMENT_OVERPAY_TOLERANCE_CENTS=0
REFERENCE_VALIDATION_MODE=deferred
DASHBOARD_DLQ_MAX_RECORDS=0
DASHBOARD_QUARANTINE_MAX_RECORDS=0
DASHBOARD_QUALITY_WARNING_CHECKS=

GENERATOR_ITERATIONS=1
GENERATOR_MAX_EVENTS=0
GENERATOR_DURATION_SECONDS=0
GENERATOR_RATE_PER_SECOND=0
GENERATOR_SLEEP_SECONDS=0
GENERATOR_FAILURE_RATE=0.12
GENERATOR_REFUND_RATE=0.06
GENERATOR_SLA_BREACH_RATE=0.08
GENERATOR_INVENTORY_SOURCE=postgres-fallback
GENERATOR_RANDOM_SEED=

GRAFANA_ADMIN_PASSWORD=change_me_grafana
