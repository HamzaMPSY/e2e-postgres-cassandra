{
  "name": "postgres-orders-prod",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "plugin.name": "pgoutput",
    "database.hostname": "${secrets:cdc/prod/postgres/orders:host}",
    "database.port": "${secrets:cdc/prod/postgres/orders:port}",
    "database.user": "${secrets:cdc/prod/postgres/orders:username}",
    "database.password": "${secrets:cdc/prod/postgres/orders:password}",
    "database.dbname": "${secrets:cdc/prod/postgres/orders:database}",
    "database.sslmode": "verify-full",
    "database.sslrootcert": "${secrets:cdc/prod/postgres/orders:ca_bundle_path}",
    "topic.prefix": "cdc.prod.omnicare.postgres",
    "slot.name": "dbz_omnicare_orders_prod",
    "publication.name": "dbz_omnicare_orders",
    "table.include.list": "public.customers,public.orders,public.order_items,public.products,public.stock_movements,public.debezium_signal",
    "snapshot.mode": "initial",
    "signal.enabled.channels": "source,kafka",
    "signal.data.collection": "public.debezium_signal",
    "signal.kafka.bootstrap.servers": "${secrets:cdc/prod/kafka:bootstrap_servers}",
    "signal.kafka.groupId": "omnicare-postgres-signals-prod",
    "signal.kafka.topic": "cdc.prod.omnicare.signals",
    "signal.kafka.security.protocol": "SSL",
    "signal.kafka.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "signal.kafka.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "signal.kafka.ssl.keystore.location": "${secrets:cdc/prod/kafka:keystore_path}",
    "signal.kafka.ssl.keystore.password": "${secrets:cdc/prod/kafka:keystore_password}",
    "heartbeat.interval.ms": "10000",
    "include.schema.changes": "true",
    "tombstones.on.delete": "true",
    "decimal.handling.mode": "string",
    "producer.override.security.protocol": "SSL",
    "producer.override.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "producer.override.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "producer.override.ssl.keystore.location": "${secrets:cdc/prod/kafka:keystore_path}",
    "producer.override.ssl.keystore.password": "${secrets:cdc/prod/kafka:keystore_password}",
    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "false"
  }
}
