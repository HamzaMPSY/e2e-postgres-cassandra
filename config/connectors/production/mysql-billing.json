{
  "name": "mysql-billing-prod",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "database.hostname": "${secrets:cdc/prod/mysql/billing:host}",
    "database.port": "${secrets:cdc/prod/mysql/billing:port}",
    "database.user": "${secrets:cdc/prod/mysql/billing:username}",
    "database.password": "${secrets:cdc/prod/mysql/billing:password}",
    "database.server.id": "${secrets:cdc/prod/mysql/billing:server_id}",
    "database.include.list": "billing",
    "database.ssl.mode": "verify_identity",
    "database.ssl.truststore": "${secrets:cdc/prod/mysql/billing:truststore_path}",
    "database.ssl.truststore.password": "${secrets:cdc/prod/mysql/billing:truststore_password}",
    "topic.prefix": "cdc.prod.omnicare.mysql",
    "table.include.list": "billing.invoices,billing.payments,billing.refunds,billing.debezium_signal",
    "schema.history.internal.kafka.bootstrap.servers": "${secrets:cdc/prod/kafka:bootstrap_servers}",
    "schema.history.internal.kafka.topic": "schema-history.prod.omnicare.mysql.billing",
    "schema.history.internal.producer.security.protocol": "SSL",
    "schema.history.internal.producer.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "schema.history.internal.producer.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "schema.history.internal.consumer.security.protocol": "SSL",
    "schema.history.internal.consumer.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "schema.history.internal.consumer.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "snapshot.mode": "initial",
    "signal.enabled.channels": "source,kafka",
    "signal.data.collection": "billing.debezium_signal",
    "signal.kafka.bootstrap.servers": "${secrets:cdc/prod/kafka:bootstrap_servers}",
    "signal.kafka.groupId": "omnicare-mysql-signals-prod",
    "signal.kafka.topic": "cdc.prod.omnicare.signals",
    "signal.kafka.security.protocol": "SSL",
    "signal.kafka.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "signal.kafka.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "include.schema.changes": "true",
    "heartbeat.interval.ms": "10000",
    "tombstones.on.delete": "true",
    "decimal.handling.mode": "string",
    "producer.override.security.protocol": "SSL",
    "producer.override.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "producer.override.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "producer.override.ssl.keystore.location": "${secrets:cdc/prod/kafka:keystore_path}",
    "producer.override.ssl.keystore.password": "${secrets:cdc/prod/kafka:keystore_password}",
    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "false"
  }
}
