{
  "name": "oracle-erp-prod",
  "config": {
    "connector.class": "io.debezium.connector.oracle.OracleConnector",
    "database.hostname": "${secrets:cdc/prod/oracle/erp:host}",
    "database.port": "${secrets:cdc/prod/oracle/erp:port}",
    "database.user": "${secrets:cdc/prod/oracle/erp:username}",
    "database.password": "${secrets:cdc/prod/oracle/erp:password}",
    "database.dbname": "${secrets:cdc/prod/oracle/erp:db_name}",
    "database.pdb.name": "${secrets:cdc/prod/oracle/erp:pdb_name}",
    "database.wallet.file": "${secrets:cdc/prod/oracle/erp:wallet_path}",
    "database.wallet.password": "${secrets:cdc/prod/oracle/erp:wallet_password}",
    "topic.prefix": "cdc.prod.omnicare.oracle",
    "database.connection.adapter": "logminer",
    "schema.include.list": "ERP_APP",
    "table.include.list": "ERP_APP.PRODUCTS,ERP_APP.SUPPLIERS,ERP_APP.STOCK_MOVEMENTS,ERP_APP.DEBEZIUM_SIGNAL",
    "snapshot.mode": "initial",
    "signal.enabled.channels": "source,kafka",
    "signal.data.collection": "ERP_APP.DEBEZIUM_SIGNAL",
    "signal.kafka.bootstrap.servers": "${secrets:cdc/prod/kafka:bootstrap_servers}",
    "signal.kafka.groupId": "omnicare-oracle-signals-prod",
    "signal.kafka.topic": "cdc.prod.omnicare.signals",
    "signal.kafka.security.protocol": "SSL",
    "signal.kafka.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "signal.kafka.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "include.schema.changes": "true",
    "heartbeat.interval.ms": "10000",
    "decimal.handling.mode": "string",
    "producer.override.security.protocol": "SSL",
    "producer.override.ssl.truststore.location": "${secrets:cdc/prod/kafka:truststore_path}",
    "producer.override.ssl.truststore.password": "${secrets:cdc/prod/kafka:truststore_password}",
    "producer.override.ssl.keystore.location": "${secrets:cdc/prod/kafka:keystore_path}",
    "producer.override.ssl.keystore.password": "${secrets:cdc/prod/kafka:keystore_password}",
    "errors.tolerance": "none",
    "errors.log.enable": "true",
    "errors.log.include.messages": "false"
  }
}
